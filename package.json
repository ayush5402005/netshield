{
  "name": "netshield",
  "version": "1.0.0",
  "private": true,
  "description": "Small-office network security gateway with DNS filtering and live dashboard.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace backend",
    "db:generate": "npm run db:generate --workspace backend",
    "db:push": "npm run db:push --workspace backend",
    "db:studio": "npm run db:studio --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
